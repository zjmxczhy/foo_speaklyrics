#include <windows.h>


#include "resource.h"





IDD_SETTINGS DIALOGEX 0, 0, 360, 360
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "朗读歌词设置"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL "自动朗读", IDC_AUTO_SPEAK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 34, 90, 12
    LTEXT "LRC歌词编码", IDC_STATIC_LRC_ENCODING, 18, 57, 80, 10
    COMBOBOX IDC_LRC_ENCODING, 156, 54, 186, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "时间偏移（毫秒，负数提前）", IDC_STATIC_LEAD, 18, 81, 132, 10
    EDITTEXT IDC_LEAD_MS, 156, 78, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "无lrc歌词后台扫描时间毫秒", IDC_STATIC_MISSING_LRC_RETRY_SECONDS, 18, 105, 132, 10
    EDITTEXT IDC_MISSING_LRC_RETRY_SECONDS, 156, 102, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "歌词朗读有效时间毫秒", IDC_STATIC_LYRIC_VALID_MS, 18, 129, 132, 10
    EDITTEXT IDC_LYRIC_VALID_MS, 156, 126, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "LRC文件", IDC_STATIC_FILE, 18, 153, 80, 10
    EDITTEXT IDC_LRC_FILE, 18, 166, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件", IDC_BROWSE_FILE, 298, 165, 44, 16
    LTEXT "LRC歌词目录", IDC_STATIC_FOLDER, 18, 188, 80, 10
    EDITTEXT IDC_LRC_FOLDER, 18, 201, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件夹", IDC_BROWSE_FOLDER, 298, 200, 44, 16
    LTEXT "歌词下载来源", IDC_STATIC_LYRIC_SOURCE_LIST, 18, 223, 100, 10
    CONTROL "", IDC_LYRIC_SOURCE_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 18, 236, 324, 34
    LTEXT "LRC歌词临时目录", IDC_STATIC_TEMP_FOLDER, 18, 273, 100, 10
    EDITTEXT IDC_TEMP_LRC_FOLDER, 18, 286, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件夹", IDC_BROWSE_TEMP_FOLDER, 298, 285, 44, 16
    LTEXT "切换歌曲删除临时lrc时间毫秒", IDC_STATIC_TEMP_LRC_DELETE_DELAY_MS, 18, 305, 150, 10
    EDITTEXT IDC_TEMP_LRC_DELETE_DELAY_MS, 174, 302, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "测试朗读", IDC_TEST_SPEAK, 12, 336, 54, 16
    DEFPUSHBUTTON "确定(&O)", IDOK, 174, 336, 50, 16
    PUSHBUTTON "取消(&C)", IDCANCEL, 228, 336, 50, 16
    PUSHBUTTON "应用(&A)", IDC_APPLY_SETTINGS, 292, 336, 50, 16
END

IDD_SEARCH_LRC DIALOGEX 0, 0, 420, 270
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "??lrc??"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    PUSHBUTTON "??????????(&A)", IDC_SEARCH_AUTO_FILL, 10, 10, 120, 16
    LTEXT "??", IDC_STATIC_SEARCH_TITLE, 10, 36, 50, 10
    EDITTEXT IDC_SEARCH_TITLE, 64, 33, 346, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "??????", IDC_STATIC_SEARCH_ARTIST, 10, 58, 50, 10
    EDITTEXT IDC_SEARCH_ARTIST, 64, 55, 346, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    DEFPUSHBUTTON "??(&S)", IDC_SEARCH_BUTTON, 10, 80, 54, 16
    CONTROL "", IDC_SEARCH_PROGRESS, "msctls_progress32", PBS_MARQUEE, 72, 82, 338, 12
    LTEXT "??", IDC_STATIC_SEARCH_RESULTS, 10, 104, 50, 10
    LISTBOX IDC_SEARCH_RESULTS, 10, 117, 400, 118, LBS_NOTIFY | LBS_NOINTEGRALHEIGHT | WS_TABSTOP | WS_BORDER | WS_VSCROLL
    PUSHBUTTON "??(&C)", IDCANCEL, 356, 246, 54, 16
END


1 VERSIONINFO


FILEVERSION 0,1,0,0


PRODUCTVERSION 0,1,0,0


BEGIN


  BLOCK "StringFileInfo"


  BEGIN


    BLOCK "040904b0"


    BEGIN


      VALUE "FileDescription", "foobar2000 LRC speech component"


    END


  END


END





