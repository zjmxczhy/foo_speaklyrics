+#include <windows.h>
+#include "resource.h"
+
+IDD_SETTINGS DIALOGEX 0, 0, 360, 160
+STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
+CAPTION "朗读歌词设置"
+FONT 9, "MS Shell Dlg", 0, 0, 0x1
+BEGIN
+    CONTROL "自动朗读", IDC_AUTO_SPEAK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 12, 12, 90, 12
+    LTEXT "前置时间（毫秒）", IDC_STATIC_LEAD, 12, 35, 90, 10
+    EDITTEXT IDC_LEAD_MS, 110, 32, 70, 14, ES_NUMBER | WS_TABSTOP | WS_BORDER
+    LTEXT "LRC文件", IDC_STATIC_FILE, 12, 59, 80, 10
+    EDITTEXT IDC_LRC_FILE, 12, 72, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
+    PUSHBUTTON "浏览文件", IDC_BROWSE_FILE, 292, 71, 54, 16
+    LTEXT "LRC歌词目录", IDC_STATIC_FOLDER, 12, 94, 80, 10
+    EDITTEXT IDC_LRC_FOLDER, 12, 107, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
+    PUSHBUTTON "浏览文件夹", IDC_BROWSE_FOLDER, 292, 106, 54, 16
+    PUSHBUTTON "测试朗读", IDC_TEST_SPEAK, 12, 136, 54, 16
+    DEFPUSHBUTTON "确定", IDOK, 228, 136, 50, 16
+    PUSHBUTTON "取消", IDCANCEL, 292, 136, 50, 16
+END
+
