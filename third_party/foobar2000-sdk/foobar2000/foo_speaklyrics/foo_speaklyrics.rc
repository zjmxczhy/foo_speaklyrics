PRODUCTVERSION 0,4,2,0


BEGIN


  BLOCK "StringFileInfo"


  BEGIN


    BLOCK "040904b0"


    BEGIN


      VALUE "FileDescription", "foobar2000 LRC speech component"


    END


  END


END





