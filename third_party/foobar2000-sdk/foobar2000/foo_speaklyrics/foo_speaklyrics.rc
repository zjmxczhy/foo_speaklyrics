#include <windows.h>


#include "resource.h"





IDD_SETTINGS DIALOGEX 0, 0, 360, 386
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "朗读歌词设置"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL "", IDC_SETTINGS_TAB, "SysTabControl32", WS_TABSTOP, 8, 8, 344, 340
    CONTROL "自动朗读", IDC_AUTO_SPEAK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 34, 90, 12
    CONTROL "切换歌曲时播报歌曲信息", IDC_ANNOUNCE_TRACK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 57, 130, 12
    LTEXT "切换歌曲播报内容", IDC_STATIC_ANNOUNCE_TRACK_FORMAT, 18, 81, 100, 10
    COMBOBOX IDC_ANNOUNCE_TRACK_FORMAT, 156, 78, 186, 90, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "切换歌曲播报延迟毫秒", IDC_STATIC_ANNOUNCE_TRACK_DELAY_MS, 18, 105, 120, 10
    EDITTEXT IDC_ANNOUNCE_TRACK_DELAY_MS, 156, 102, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "LRC歌词编码", IDC_STATIC_LRC_ENCODING, 18, 129, 80, 10
    COMBOBOX IDC_LRC_ENCODING, 156, 126, 186, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "设定朗读器前置时间毫秒", IDC_STATIC_LEAD, 18, 153, 132, 10
    EDITTEXT IDC_LEAD_MS, 156, 150, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "无lrc歌词后台扫描时间毫秒", IDC_STATIC_MISSING_LRC_RETRY_SECONDS, 18, 177, 132, 10
    EDITTEXT IDC_MISSING_LRC_RETRY_SECONDS, 156, 174, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "歌词朗读有效时间毫秒", IDC_STATIC_LYRIC_VALID_MS, 18, 201, 132, 10
    EDITTEXT IDC_LYRIC_VALID_MS, 156, 198, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    CONTROL "启动后隐藏 foobar2000 主窗口", IDC_HIDE_MAIN_WINDOW_ON_STARTUP, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 225, 130, 12
    LTEXT "启动后隐藏主窗口延迟毫秒", IDC_STATIC_HIDE_MAIN_WINDOW_DELAY_MS, 18, 249, 120, 10
    EDITTEXT IDC_HIDE_MAIN_WINDOW_DELAY_MS, 156, 246, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "歌词下载来源", IDC_STATIC_LYRIC_SOURCE_LIST, 18, 34, 100, 10
    CONTROL "", IDC_LYRIC_SOURCE_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 18, 47, 324, 58
    CONTROL "下载到指定的歌词目录", IDC_DOWNLOAD_TO_LRC_FOLDER, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 112, 130, 12
    LTEXT "LRC文件", IDC_STATIC_FILE, 18, 136, 80, 10
    EDITTEXT IDC_LRC_FILE, 18, 149, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件", IDC_BROWSE_FILE, 298, 148, 44, 16
    LTEXT "LRC歌词目录", IDC_STATIC_FOLDER, 18, 171, 80, 10
    EDITTEXT IDC_LRC_FOLDER, 18, 184, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件夹", IDC_BROWSE_FOLDER, 298, 183, 44, 16
    LTEXT "LRC歌词临时目录", IDC_STATIC_TEMP_FOLDER, 18, 206, 100, 10
    EDITTEXT IDC_TEMP_LRC_FOLDER, 18, 219, 270, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "浏览文件夹", IDC_BROWSE_TEMP_FOLDER, 298, 218, 44, 16
    LTEXT "切换歌曲删除临时lrc时间毫秒", IDC_STATIC_TEMP_LRC_DELETE_DELAY_MS, 18, 241, 150, 10
    EDITTEXT IDC_TEMP_LRC_DELETE_DELAY_MS, 174, 238, 70, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    CONTROL "使用屏幕阅读器", IDC_USE_SCREEN_READER, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 34, 120, 12
    LTEXT "选择语音", IDC_STATIC_TTS_VOICE, 18, 62, 80, 10
    COMBOBOX IDC_TTS_VOICE, 18, 76, 324, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "语速", IDC_STATIC_TTS_RATE, 18, 106, 80, 10
    CONTROL "", IDC_TTS_RATE, "msctls_trackbar32", TBS_AUTOTICKS | TBS_TOOLTIPS | WS_TABSTOP, 18, 120, 260, 24
    LTEXT "0", IDC_TTS_RATE_VALUE, 288, 124, 54, 10
    LTEXT "试听文本", IDC_STATIC_TTS_TEST_TEXT, 18, 154, 80, 10
    EDITTEXT IDC_TTS_TEST_TEXT, 18, 168, 324, 44, ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_TABSTOP | WS_BORDER | WS_VSCROLL
    PUSHBUTTON "试听(&T)", IDC_TTS_TEST, 18, 222, 54, 16
    LTEXT "主要用途", IDC_STATIC_ABOUT_PURPOSE, 18, 34, 80, 10
    EDITTEXT IDC_ABOUT_PURPOSE, 18, 47, 324, 54, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_TABSTOP | WS_BORDER | WS_VSCROLL
    PUSHBUTTON "查看GitHub仓库", IDC_ABOUT_GITHUB_REPO, 18, 116, 96, 18
    PUSHBUTTON "前往GitHub发布页", IDC_ABOUT_GITHUB_RELEASES, 18, 144, 108, 18
    PUSHBUTTON "备用gitee发布页", IDC_ABOUT_GITEE_RELEASES, 18, 172, 96, 18
    DEFPUSHBUTTON "确定(&O)", IDOK, 174, 362, 50, 16
    PUSHBUTTON "取消(&C)", IDCANCEL, 228, 362, 50, 16
    PUSHBUTTON "应用(&A)", IDC_APPLY_SETTINGS, 292, 362, 50, 16
END

IDD_SEARCH_LRC DIALOGEX 0, 0, 420, 270
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "??lrc??"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    PUSHBUTTON "??????????(&A)", IDC_SEARCH_AUTO_FILL, 10, 10, 120, 16
    LTEXT "??", IDC_STATIC_SEARCH_TITLE, 10, 36, 50, 10
    EDITTEXT IDC_SEARCH_TITLE, 64, 33, 346, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "??????", IDC_STATIC_SEARCH_ARTIST, 10, 58, 50, 10
    EDITTEXT IDC_SEARCH_ARTIST, 64, 55, 346, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    DEFPUSHBUTTON "??(&S)", IDC_SEARCH_BUTTON, 10, 80, 54, 16
    CONTROL "", IDC_SEARCH_PROGRESS, "msctls_progress32", PBS_MARQUEE, 72, 82, 338, 12
    LTEXT "??", IDC_STATIC_SEARCH_RESULTS, 10, 104, 50, 10
    LISTBOX IDC_SEARCH_RESULTS, 10, 117, 400, 118, LBS_NOTIFY | LBS_NOINTEGRALHEIGHT | WS_TABSTOP | WS_BORDER | WS_VSCROLL
    PUSHBUTTON "??(&C)", IDCANCEL, 356, 246, 54, 16
END

IDD_ADD_TIMESTAMP_LRC DIALOGEX 0, 0, 460, 320
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "???????"
FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT "????", IDC_STATIC_TIMESTAMP_TIME, 10, 12, 70, 10
    EDITTEXT IDC_TIMESTAMP_TIME, 86, 9, 120, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON "????(&T)", IDC_TIMESTAMP_REFRESH_TIME, 214, 8, 82, 16
    LTEXT "??????", IDC_STATIC_TIMESTAMP_TEXT, 10, 36, 70, 10
    EDITTEXT IDC_TIMESTAMP_TEXT, 86, 33, 364, 14, ES_AUTOHSCROLL | WS_TABSTOP | WS_BORDER
    LTEXT "??", IDC_STATIC_TIMESTAMP_ENCODING, 10, 60, 70, 10
    COMBOBOX IDC_TIMESTAMP_ENCODING, 86, 57, 180, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "??(&S)", IDC_TIMESTAMP_SAVE, 10, 84, 54, 16
    PUSHBUTTON "???(&A)", IDC_TIMESTAMP_SAVE_AS, 70, 84, 62, 16
    PUSHBUTTON "??(&O)", IDC_TIMESTAMP_OPEN, 138, 84, 54, 16
    LTEXT "??", IDC_STATIC_TIMESTAMP_PREVIEW, 10, 112, 70, 10
    EDITTEXT IDC_TIMESTAMP_PREVIEW, 10, 125, 440, 158, ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_TABSTOP | WS_BORDER | WS_VSCROLL
    PUSHBUTTON "??(&C)", IDCANCEL, 396, 296, 54, 16
END


